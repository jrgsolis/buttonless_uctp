<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>UCTP SDK Buttonless Demo | Use Cases </title>

  <style>
    :root{
      --bg:#f6f7fb; --surface:#ffffff; --text:#0f172a; --muted:#64748b; --line:#e6e8ef;
      --line-strong:#d7dce3; --shadow:0 8px 24px rgba(15,23,42,.06); --radius:16px;
      --accent:#2563eb; --accent2:#1d4ed8; --ok:#16a34a; --warn:#d97706; --err:#dc2626;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:var(--text);background:var(--bg)}
    header{position:sticky;top:0;z-index:10;background:rgba(246,247,251,.88);backdrop-filter:blur(10px);border-bottom:1px solid var(--line)}
    .topbar{max-width:1280px;margin:0 auto;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;gap:12px}
    .brand{display:flex;align-items:center;gap:10px;font-weight:800;letter-spacing:.2px}
    .brand small{display:block;color:var(--muted);font-weight:700;margin-top:2px}
    .status-pill{display:flex;gap:8px;align-items:center;padding:8px 10px;border-radius:999px;background:var(--surface);border:1px solid var(--line);box-shadow:0 2px 10px rgba(15,23,42,.03);font-size:12px;color:var(--muted);white-space:nowrap}
    .dot{width:8px;height:8px;border-radius:999px;background:#cbd5e1}.dot.ok{background:var(--ok)} .dot.err{background:var(--err)} .dot.warn{background:var(--warn)}
    .page{max-width:1280px;margin:0 auto;padding:18px;display:flex;flex-direction:column;gap:16px}
    .card,.checkout-panel,.ux-panel,.dev-panel{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden}
    .card-head{padding:14px 16px;border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;gap:10px}
	.card-head h2{
	  display:flex;
	  align-items:center;
	}
    .sub{font-size:12px;color:var(--muted);margin-top:4px;line-height:1.35}
    .toolbar{display:flex;gap:10px;align-items:center;width:100%;justify-content:flex-end}
    .search{width:340px;max-width:50vw;position:relative}
    .search input{width:100%;padding:10px 12px 10px 36px;border-radius:12px;border:1px solid var(--line);outline:none;font-size:13px;background:#fbfcfe;color:var(--text)}
    .search .icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:14px}
    .catalog-grid{padding:14px 16px 16px;display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px}
    @media (max-width:1100px){.catalog-grid{grid-template-columns:repeat(3,minmax(0,1fr))}}
    @media (max-width:760px){.catalog-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.search{width:100%;max-width:100%}.toolbar{justify-content:stretch}}
    @media (max-width:540px){.catalog-grid{grid-template-columns:1fr}}
    .product{border:1px solid var(--line);border-radius:14px;overflow:hidden;background:#fff;display:flex;flex-direction:column;min-height:255px}
    .product img{width:100%;height:132px;object-fit:cover;background:#f1f5f9}
    .pbody{padding:12px;display:flex;flex-direction:column;gap:8px;flex:1}
    .ptop{display:flex;align-items:flex-start;justify-content:space-between;gap:10px}
    .pname{font-weight:800;font-size:13px;line-height:1.25}.pprice{font-weight:900;color:var(--accent);font-size:13px;white-space:nowrap}
    .pdesc{font-size:12px;color:var(--muted);line-height:1.35;min-height:34px}
    .pactions{margin-top:auto;display:flex;align-items:center;justify-content:space-between;gap:8px}
    button{border:none;cursor:pointer;border-radius:12px;padding:10px 12px;font-weight:800;font-size:13px}
    .btn{background:var(--accent);color:#fff}.btn:hover{background:var(--accent2)}.btn:disabled{opacity:.55;cursor:not-allowed}
    .btn-ghost{background:#fff;border:1px solid var(--line);color:var(--text);font-weight:800}
    .btn-mini{padding:8px 10px;border-radius:10px;font-size:12px}
    .qty{display:flex;align-items:center;gap:6px;color:var(--muted);font-size:12px;white-space:nowrap}
    .main-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:16px;align-items:start}
    @media (max-width:980px){.main-grid{grid-template-columns:1fr}}
    .checkout-body{display:flex;flex-direction:column;gap:14px;padding:16px}
    .ux-body,.dev-body{padding:16px}
    .cart-items{display:flex;flex-direction:column;gap:10px;max-height:240px;overflow:auto;padding-right:4px}
    .cart-item{display:flex;gap:10px;align-items:center;border:1px solid var(--line);border-radius:14px;padding:10px;background:#fff}
    .cart-item img{width:46px;height:46px;border-radius:12px;object-fit:cover;background:#f1f5f9;border:1px solid var(--line)}
    .ci-main{flex:1;min-width:0}.ci-title{margin:0;font-weight:900;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .ci-sub{margin:3px 0 0;display:flex;gap:10px;align-items:center;color:var(--muted);font-size:12px}
    .ci-controls{display:flex;gap:6px;align-items:center}
    .chip{font-size:11px;padding:4px 8px;border-radius:999px;border:1px solid var(--line);background:#fbfcfe;color:var(--muted);white-space:nowrap}
    .totals{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border:1px dashed var(--line-strong);border-radius:14px;background:#fbfcfe;font-weight:900}
    .field label{display:block;font-size:12px;font-weight:800;color:var(--muted);margin:6px 0 6px;text-transform:none;letter-spacing:0}
    .field input{width:100%;padding:10px 12px;border-radius:12px;border:1px solid var(--line);outline:none;background:#fbfcfe;font-size:13px}
    .steps{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    @media (max-width:1100px){.steps{grid-template-columns:repeat(2,minmax(0,1fr))}}
    @media (max-width:700px){.steps{grid-template-columns:1fr}}
    .step{background:#fafbfc;border:1px solid #d9dde3;border-radius:12px;padding:16px;box-shadow:none}
    .step-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;gap:10px}
    .step-title{font-size:14px;font-weight:700;color:#1f2937}
    .step-state{font-size:11px;font-weight:800;padding:5px 10px;border-radius:999px;border:1px solid #cbd5e1;background:#e2e8f0;color:#334155;white-space:nowrap;letter-spacing:.02em}
    .step-state.ok{border-color:#166534;background:#16a34a;color:#fff}
    .step-state.err{border-color:#991b1b;background:#dc2626;color:#fff}
    .step-state.warn{border-color:#92400e;background:#d97706;color:#fff}
    .hint{font-size:12px;color:var(--muted);line-height:1.45;margin-bottom:12px}
    input,select{width:100%;height:42px;border:1px solid #cfd6df;border-radius:4px;background:#fff;padding:0 10px;font-size:13px;color:#1f2937;box-sizing:border-box}
    input::placeholder{color:#98a2b3}
    label{display:block;font-size:11px;font-weight:600;color:#6b7280;letter-spacing:.02em;margin:10px 0 6px;text-transform:uppercase}
    details{border:1px solid var(--line);border-radius:14px;background:#fff;overflow:hidden}
    summary{cursor:pointer;padding:10px 12px;font-weight:900;font-size:13px;color:var(--text);user-select:none}
    .log{border-top:1px solid var(--line);background:#0b1020;color:#d1d5db;padding:10px;font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono",monospace;font-size:11px;white-space:pre-wrap;line-height:1.35;max-height:220px;overflow:auto}
    .note{padding:10px 16px 14px;border-top:1px solid var(--line);background:#fbfcfe;font-size:12px;color:var(--muted);line-height:1.35}
    .btn-ctp-primary{width:100%;height:44px;border:none;border-radius:4px;background:#1d2433;color:#fff;font-size:14px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;padding:0 14px}
    .btn-ctp-primary:hover{background:#161c28}.btn-ctp-primary:disabled{opacity:.55;cursor:not-allowed}
    .btn-ctp-secondary{width:100%;height:44px;border:1px solid #cfd6df;border-radius:4px;background:#fff;color:#1f2937;font-size:14px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0 14px}
    .btn-ctp-secondary:hover{background:#f8fafc}
    .ctp-payment-header{display:flex;align-items:center;gap:12px;margin-bottom:14px}
    .ctp-payment-icon{width:54px;height:auto;display:block;flex:0 0 auto}
    .ctp-payment-title{font-size:17px;font-weight:600;color:#1f2937;line-height:1.2}
    .ctp-subtext{font-size:13px;line-height:1.45;color:#5b6472;margin-bottom:12px}
    .saved-card{display:flex;align-items:center;gap:12px;border:1px solid #d7dce3;border-radius:6px;background:#fff;padding:10px 12px;margin-bottom:8px;cursor:pointer;min-height:72px}
    .saved-card:hover{border-color:#aeb7c2;background:#fcfcfd}
    .saved-card input[type="radio"]{width:16px;height:16px;margin:0 2px 0 0;accent-color:#111827;flex:0 0 auto}
    .saved-card-art{width:54px;height:34px;border-radius:4px;object-fit:cover;border:1px solid #d7dce3;background:#f3f4f6;flex:0 0 auto}
    .saved-card-main{display:flex;flex-direction:column;justify-content:center;min-width:0;gap:4px}
    .saved-card-title{font-size:13px;font-weight:600;color:#1f2937;line-height:1.2}
    .saved-card-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;font-size:12px;color:#4b5563;line-height:1.2}
    .saved-card-brand-logo{height:16px;width:auto;display:block;object-fit:contain}
    .saved-card-last4{font-size:12px;color:#374151}
    .saved-card-expiry{font-size:11px;color:#6b7280}
    .ctp-divider{text-align:center;color:#8b93a1;font-size:12px;margin:14px 0;position:relative}
    .ctp-divider:before,.ctp-divider:after{content:"";position:absolute;top:50%;width:38%;height:1px;background:#d7dce3}
    .ctp-divider:before{left:0}.ctp-divider:after{right:0}
    .link-ctp-row{margin-top:10px;border:1px solid #d7dce3;border-radius:4px;background:#fff;padding:10px 12px}
    .link-ctp-label{display:flex;align-items:center;gap:10px;font-size:13px;color:#1f2937;text-transform:none;margin:0;font-weight:500;letter-spacing:0}
    .link-ctp-label input[type="checkbox"]{width:16px;height:16px;margin:0;accent-color:#111827}
    .link-ctp-icon{width:26px;height:auto;display:block;flex:0 0 auto}
    .ctp-compact-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:10px}
	.toggle-btn{
	  margin-left:10px;
	  width:28px;
	  height:28px;

	  border:1px solid #ccc;
	  border-radius:4px;

	  background:#fff;
	  cursor:pointer;

	  font-size:18px;
	  font-weight:700;

	  display:inline-flex;
	  align-items:center;
	  justify-content:center;

	  line-height:1;
	}

	.toggle-btn:hover{
	  background:#f2f2f2;
	}
	.checkout-box {
	  border: 1px solid #cfcfcf;
	  background: #fff;
	}

	.checkout-box-header {
	  padding: 14px 18px;
	  font-size: 15px;
	  font-weight: 600;
	  background: #e9edf3;
	  border-bottom: 1px solid #cfcfcf;
	}

	.section-title {
	  margin: 18px 18px 10px;
	  font-size: 12px;
	  letter-spacing: 1.5px;
	  color: #5d6880;
	}

	.field-group {
	  margin: 0 18px 14px;
	}

	.field-row {
	  display: flex;
	  gap: 14px;
	  margin: 0 18px 14px;
	}

	.field-row input {
	  flex: 1;
	}

	input {
	  width: 100%;
	  height: 56px;
	  padding: 0 14px;
	  border: 1px solid #cfcfcf;
	  box-sizing: border-box;
	  font-size: 14px;
	}

	button {
	  width: 100%;
	  height: 48px;
	  border: 0;
	  background: #1f2430;
	  color: #fff;
	  font-size: 16px;
	  font-weight: 600;
	  cursor: pointer;
	}

	button:disabled {
	  background: #cfcfcf;
	  cursor: not-allowed;
	}

	.info-panel {
	  margin: 0 18px 14px;
	  padding: 14px;
	  border: 1px solid #cfcfcf;
	  background: #fff;
	}

	.info-label {
	  display: block;
	  font-size: 12px;
	  letter-spacing: 1px;
	  color: #5d6880;
	  margin-bottom: 6px;
	}

	.info-value {
	  font-size: 15px;
	  color: #222;
	}
    .hidden{display:none !important}
  </style>
</head>

<body>
<header>
  <div class="topbar">
    <div class="brand">
      <span style="font-size:18px">🧾</span>
      <div>
        UCTP Buttonless Demo - Render Cards
        <small>VAS Acceptance Product</small>
      </div>
    </div>

    <div class="status-pill" id="sdkPill">
      <span class="dot" id="sdkDot"></span>
      <span id="sdkText">SDK: not loaded</span>
    </div>
	<div class="status-pill" id="flowPill">
	  <span class="dot warn"></span>
	  <span id="flowText">FLOW: waiting</span>
	</div>
  </div>
  

</header>

<div class="page">

 
  <section class="card">

    <div class="card-head">
      
      <div>
        <h2>
          Catálogo
         <button id="btnToggleCatalog" class="toggle-btn" onclick="toggleCatalog()" aria-label="Toggle catalog"></button>
        </h2>

        <div class="sub">
          Agrega productos al carrito. Luego ejecuta Session → Initialize
        </div>
      </div>

      <div class="toolbar">
        <div class="search">
          <span class="icon">⌕</span>
          <input id="q" placeholder="Buscar..." oninput="renderCatalog()" />
        </div>
      </div>

    </div>

    <!-- CONTENIDO COLAPSABLE -->
    <div id="catalogContent">

      <div class="catalog-grid" id="catalog"></div>

      <div class="note">
        Este Demo pertenece a <b>LAC VAS Acceptance</b>. Desarrollado por <b>Merilin Ospino Reales - Directora</b>.
      </div>

    </div>

  </section>
  
  
  <section class="main-grid">

    <aside class="checkout-panel">
      <div class="card-head">
        <div>
          <h3>Checkout</h3>
          <div class="sub">Carrito, total y email lookup.</div>
        </div>
        <button class="btn-ghost btn-mini" onclick="clearCart()">Vaciar</button>
      </div>

      <div class="checkout-body">
        <div class="cart-items" id="cartItems"></div>

        <div class="totals">
          <div>Total</div>
          <div>$<span id="total">0.00</span></div>
        </div>

   <!--      <div class="field">
          <label for="email">Email Lookup</label>
          <input id="email" placeholder="test@email.com" />
        </div>
      </div>
	  -->
	  
	  <!-- VISTA Guest Checkout -->
	  <div id="guestCheckoutPanel" class="checkout-box">

	    <div class="checkout-box-header">
	      Continue as a guest
	    </div>

	    <!-- VISTA INICIAL -->
	    <div id="guestEntryView">
	      <div class="section-title">Informacion de Contacto</div>

	      <div class="field-group">
	        <input
	          id="email"
	          type="email"
	          placeholder="Direccion Email"
	          oninput="handleGuestEmailInput()"
	        />
	      </div>

	      <div class="field-group">
	        <button
	          id="btnGuestContinue"
	          onclick="continueAsGuest()"
	          disabled
	        >
	          Continue as a guest
	        </button>
	      </div>
	    </div>

	    <!-- VISTA RESUMEN + SHIPPING -->
	    <div id="guestShippingView" style="display:none;">
	      <div class="section-title">CONTACT INFORMATION</div>

	      <div class="info-panel" style="margin-bottom:16px;">
	        <label class="info-label">EMAIL ADDRESS</label>
	        <div id="guestEmailLabel" class="info-value"></div>
	      </div>

	      <div class="section-title">SHIPPING INFORMATION</div>

	      <div class="field-row">
	        <input id="firstName" type="text" placeholder="FIRST NAME" />
	        <input id="lastName" type="text" placeholder="LAST NAME" />
	      </div>

	      <div class="field-group">
	        <input id="mobileNumber" type="text" placeholder="MOBILE NUMBER" />
	      </div>

	      <div class="field-group">
	        <input id="address1" type="text" placeholder="ADDRESS LINE 1" />
	      </div>

	      <div class="field-group">
	        <input id="address2" type="text" placeholder="ADDRESS LINE 2 (OPTIONAL)" />
	      </div>

	      <div class="field-group">
	        <input id="country" type="text" placeholder="COUNTRY" />
	      </div>

	      <div class="field-group">
	        <input id="city" type="text" placeholder="CITY/TOWN" />
	      </div>

	      <div class="field-row">
	        <input id="state" type="text" placeholder="STATE" />
	        <input id="zip" type="text" placeholder="ZIP" />
	      </div>

	      <div class="field-group" style="margin-top:16px;">
	        <!-- <button id="btnGuestFlowContinue" onclick="continueGuestFlow()">
	          Continue
	        </button>-->
			
			<button id="btnGuestFlowContinue">
			          Continue
			        </button>
	      </div>
	    </div>

	  </div>
	  
	  
	  
	  
	  
	  
    </aside>

    <aside class="ux-panel">
      <div class="card-head">
        <div>
          <h3>Customer Payment Experience</h3>
          <div class="sub">Vista del cliente alineada a Click to Pay.</div>
        </div>
      </div>

      <div class="ux-body">

        <div class="step hidden" id="otpPanel">
          <div class="ctp-payment-header">
			<img src="/images/ctp/Click_to_Pay_helper_image.jpg" alt="Click to Pay" class="ctp-payment-icon" />
			<div class="ctp-payment-title">Pago con tarjeta</div>
          </div>

          <div class="ctp-subtext" id="otpMessage">
            Click to Pay ha encontrado sus tarjetas. Ingresa el código enviado para continuar.
          </div>

          <label for="otpCode">Enter code</label>
          <input id="otpCode" placeholder="Ingresa código aquí" />

          <div style="margin-top:12px;">
            <button class="btn-ctp-primary" id="btnOtp" onclick="verifyOtp()">
              Verificar y continuar
            </button>
          </div>

          <div class="ctp-divider">O</div>

          <button class="btn-ctp-secondary" onclick="showGuestCardPanel(true)">
            Ingrese una nueva tarjeta
          </button>
        </div>

        <div class="step hidden" id="savedCardsPanel">
          <div class="ctp-payment-header">
			<img src="/images/ctp/Click_to_Pay_helper_image.jpg" alt="Click to Pay" class="ctp-payment-icon" />
			<div class="ctp-payment-title">Pago con tarjeta</div>
          </div>

          <div class="ctp-subtext">
            Click to Pay encontró sus tarjetas vinculadas.
          </div>

          <div id="savedCardsList"></div>

          <div style="margin-top:12px;">
            <button class="btn-ctp-primary" onclick="submitCheckout()" id="btnCheckout" disabled>
              <span>🔒</span>
              <span>Pagar</span>
            </button>
          </div>

          <div class="ctp-divider">O</div>

          <button class="btn-ctp-secondary" onclick="showGuestCardPanel(true)">
            Ingresar tarjeta manualmente
          </button>
        </div>
		
		

        <div class="step hidden" id="guestCardPanel">
        
		  <div class="ctp-payment-header">
			<img src="/images/ctp/Click_to_Pay_helper_image.jpg" alt="Click to Pay" class="ctp-payment-icon" />
			<div class="ctp-payment-title">Pago con tarjeta</div>
          </div>
		  
		  <div id="guestCardBrandRow">
		    <img
		      id="guestCardBrandLogo"
		      src=""
		      alt="Card brand"
		      style="height:20px;width:auto;display:none;object-fit:contain;"
		    />
		    <span id="guestCardBrandText" style="font-size:12px;color:#64748b;"></span>
	          <label>Número de tarjeta</label>
			  <input
			    id="guestCardNumber"
			    placeholder="4000 8910 1112 1234"
			    inputmode="numeric"
			    autocomplete="cc-number"
			    maxlength="23"
			    oninput="formatCardNumberInput(this)"
			  />
		  </div>
		  
          <div class="ctp-compact-grid">
            <div>
              <label>Fecha de exp. (MM/YY)</label>
			  <input
			    id="guestExpiry"
			    placeholder="11/26"
			    inputmode="numeric"
			    autocomplete="cc-exp"
			    maxlength="5"
			    oninput="formatExpiryInput(this)"
			  />
            </div>
            <div>
              <label>CVV</label>
			  <input
			    type="password"
			    id="cvv"
			    placeholder="123"
			    inputmode="numeric"
			    autocomplete="cc-csc"
			    maxlength="4"
			  />
            </div>
          </div>

          <div class="link-ctp-row">
            <label class="link-ctp-label">
              <input type="checkbox" id="linkCardToCtp" />
              <img src="/images/Click_to_Pay_Icon_black.jpg" alt="Click to Pay icon" class="link-ctp-icon" />
              <span>Agregar esta tarjeta a Click to Pay</span>
            </label>
          </div>
		  
		  <!-- Bloque de vinculación -->
		  		    <div id="guestLinkingInfoSection" class="ctp-linking-info-section" >
		  		      <div class="sub">
		  		        Esta tarjeta se vinculará usando la siguiente información:
		  		      </div>

		  		      <div class="ctp-linking-card">
		  		        <div class="ctp-linking-card-header">
		  		          <div>
		  		            <div id="ctpConsumerDisplayName" class="sub">Merilin Ospino</div>
		  		            <div id="ctpConsumerDisplayEmail" class="sub">m*********o@gmail.com</div>
		  		            <div id="ctpConsumerDisplayPhone" class="sub">+57********2279</div>
		  		          </div>
		  		        </div>
		  		      </div>

		  		      <div class="sub">
		  		        Al hacer clic en el botón de pago, aceptas los
		  		        <a href="#" target="_blank" rel="noopener noreferrer">Términos</a>
		  		        de Click to Pay y entiendes que tus datos serán procesados de acuerdo con la
		  		        <a href="#" target="_blank" rel="noopener noreferrer">Política de Privacidad</a>.
		  		        Te enviaremos un correo electrónico de confirmación.
		  		      </div>
		  		    </div>



	          <div style="margin-top:12px;">
	            <button class="btn-ctp-primary"  onclick="submitCheckout()">
	              <span>🔒</span>
	              <span>Pagar</span>
	            </button>
	          </div>
		  
        </div>
		
		<div id="paymentSuccessPanel" class="panel hidden">
		  <div style="text-align:center;padding:20px">
			<div style="font-size:48px;color:#16a34a">✔</div>
		    <h3 style="color:#16a34a;margin-bottom:10px">
		      Pago exitoso
		    </h3>

		    <p style="color:#475569">
		      La transacción fue procesada correctamente por la pasarela de pago.
		    </p>

		    <p style="font-size:12px;color:#64748b;margin-top:8px">
		      (Simulación para demo – no se usó Click to Pay)
		    </p>

		    <button class="btn" onclick="resetUxFlowState()" style="margin-top:15px">
		      Nueva compra
		    </button>

		  </div>
		</div>

        <div id="uxEmptyState" class="step">
          <div class="ctp-payment-header">
            <img src="/images/ctp/Click_to_Pay_helper_image.jpg" alt="Click to Pay" class="ctp-payment-icon" />
            <div class="ctp-payment-title">Pago con tarjeta</div>
          </div>

          <div class="ctp-subtext">
            Inicia el flujo con <b>Crear sesión</b>, <b>Initialize</b>, <b>Ver tarjetas</b> y <b>Checkout</b> para mostrar la experiencia Click to Pay.
          </div>

          <button class="btn-ctp-secondary" disabled>
            Esperando flujo
          </button>
        </div>

      </div>
    </aside>

  </section>

  <section class="dev-panel">
    <div class="card-head">
      <div>
        <h3>Developer Steps</h3>
        <div class="sub">Controles del flujo técnico con visual sobrio, alineado al UI principal.</div>
      </div>
    </div>

	<div class="dev-body">

	  <div class="steps">

	    <!-- SESSION -->
	    <div class="step">
	      <div class="step-top">
	        <div class="step-title">1) Crear sesión</div>
	        <div class="step-state" id="s1">Ready</div>
	      </div>

	      <div class="hint">
	        Llama <b>/api/sessions</b>. Obtiene <b>captureContextJwt</b> y <b>clientLibrary</b>.
	      </div>

	      <button class="btn" onclick="createSessionOnly()" id="btnSession" disabled>
	        Crear sesión
	      </button>
	    </div>


	    <!-- INITIALIZE -->
	    <div class="step">
	      <div class="step-top">
	        <div class="step-title">2) Initialize SDK</div>
	        <div class="step-state" id="s2">Locked</div>
	      </div>

	      <div class="hint">
	        Carga <b>UnifiedClickToPay.js</b> y ejecuta <b>initialize(jwt)</b>.
	      </div>

	      <button class="btn" onclick="initializeSdkOnly()" id="btnInit" disabled>
	        Initialize
	      </button>
	    </div>


	    <!-- FLOW 1 -->
	    <div class="step">
	      <div class="step-top">
	        <div class="step-title">3A) Get Cards</div>
	        <div class="step-state" id="s3">Locked</div>
	      </div>

	      <div class="hint">
	        <b>getCards(email)</b> identifica al consumidor.<br>
	        Si el perfil existe, Click to Pay envía <b>OTP</b> para validación de identidad.
	      </div>

	      <button class="btn" onclick="runExistingUserLookup()" id="btnGetCards" disabled>
	        Ver tarjetas
	      </button>
	    </div>


	    <!-- FLOW 2 -->
	    <div class="step">
	      <div class="step-top">
	        <div class="step-title">3B) Linking a Card</div>
	        <div class="step-state" id="s3b">Locked</div>
	      </div>

	      <div class="hint">
	        El usuario ingresa una nueva tarjeta y puede
	        <b>vincularla a Click to Pay</b> antes del pago.
	      </div>

	      <button class="btn" onclick="showGuestCardPanel(true)" id="btnAddCard" disabled>
	        Ingresar tarjeta
	      </button>
	    </div>


	    <!-- CHECKOUT -->
	    <div class="step">
	      <div class="step-top">
	        <div class="step-title">4) Checkout</div>
	        <div class="step-state" id="s4">Locked</div>
	      </div>
		 
	      <div class="hint">
	        Ejecuta <b>checkout()</b> con la tarjeta seleccionada o manual.
	        Devuelve payload tokenizado para autorización.
	      </div>

	      <button class="btn" onclick="submitCheckout()" id="btnCheckoutDev" disabled>
	        Checkout
	      </button>
	    </div>

	  </div>


	  <div style="margin-top:14px;">
	    <details>
	      <summary>Debug (opcional)</summary>
	      <div class="log" id="log"></div>
	    </details>
	  </div>

	</div>
    </div>
  </section>

</div>

<script>
  const STATIC_ASSETS = {
    ctpIcon: "/Images/ctp/Click_to_Pay_helper_image.jpg",
    visaLogo: "/Images/brands/VisaLogo.png",
    amexLogo: "/Images/brands/AmexLogo.png",
    visaArt: "/Images/cardarts/visacardart.jfif",
    amexArt: "/Images/cardarts/cardamex2.png",
    mcArt: "/Images/cardarts/mccardart.jpg",
    mcLogoFallback: "/Images/brands/MCLogo.jfif"
  };

  const state = {
    catalog: [
      { id:"b1", name:"Burger Clásica", price:6.80, desc:"Carne, queso, lechuga y salsa.", img:"/images/burger.jpg" },
      { id:"p1", name:"Pizza Pepperoni", price:7.40, desc:"Pepperoni + mozzarella.", img:"/images/pizza.jpg" },
      { id:"s1", name:"Sushi Mix", price:9.50, desc:"12 piezas variadas.", img:"/images/sushi.jpg" },
      { id:"t1", name:"Tacos", price:5.90, desc:"3 tacos con guacamole.", img:"/images/tacos.jpg" },
      { id:"k1", name:"Bowl Saludable", price:6.20, desc:"Proteína + vegetales.", img:"/images/bowl.jpg" },
      { id:"d1", name:"Postre", price:3.50, desc:"Dulce para cerrar.", img:"/images/dessert.jpg" }
    ],
	cart: new Map(),
	  session: null,
	  sdk: null,
	  cards: [],
	  selectedCardIndex: 0,
	  captureContext: null,
	  captureContextJwt: null,
	  captureContextDecoded: null,
	  panEncryptionKeys: {},
	  getCardsContext : null,
	  pendingConsumerIdentity: null,
	  pendingManualCheckout: null,
	  currentUxFlow: null
  };

  const $ = (id) => document.getElementById(id);

  function money(n){
    return (Math.round(n * 100) / 100).toFixed(2);
  }

  function setPill(ok, text){
    $("sdkText").textContent = text;
    $("sdkDot").className = "dot " + (ok === true ? "ok" : ok === false ? "err" : "warn");
  }

  function setStep(id, type, label){
    const el = $(id);
    if (!el) return;
    el.className = "step-state" + (type ? (" " + type) : "");
    el.textContent = label;
  }

  function setCheckoutButtonsEnabled(enabled){
    if ($("btnCheckout")) $("btnCheckout").disabled = !enabled;
    if ($("btnCheckoutDev")) $("btnCheckoutDev").disabled = !enabled;
  }

  function logLine(...args){
    const msg = args.map(a => typeof a === "string" ? a : JSON.stringify(a, null, 2)).join(" ");
    $("log").textContent += msg + "\n";
    $("log").scrollTop = $("log").scrollHeight;
    console.log(...args);
  }

  function escapeHtml(s){
    return String(s ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#039;");
  }

  function safeJsonParse(text){
    try { return JSON.parse(text); }
    catch { return { raw:text }; }
  }

  function updateCreateSessionButtonFromTotal(){
    const txt = $("total").textContent || "0";
    const total = Number(txt.replace(/[^0-9.]/g,""));
    const valid = Number.isFinite(total) && total > 0;
    $("btnSession").disabled = !valid;
  }

  
  
//  function $(id) {
  //  return document.getElementById(id);
  //}
  
  function validateShippingFields() {
    const requiredIds = [
      "firstName",
      "lastName",
      "mobileNumber",
      "address1",
      "country",
      "city",
      "state",
      "zip"
    ];

    for (const id of requiredIds) {
      const value = ($(id)?.value || "").trim();
      if (!value) {
        throw new Error(`Completa el campo ${id}.`);
      }
    }
  }
  function renderCatalog(){
    const q = ($("q").value || "").toLowerCase().trim();
    const items = state.catalog.filter(p =>
      !q || (p.name.toLowerCase().includes(q) || p.desc.toLowerCase().includes(q))
    );

    $("catalog").innerHTML = items.map(p => {
      const qty = state.cart.get(p.id) || 0;
      return `
        <div class="product">
          <img src="${p.img}" alt="${escapeHtml(p.name)}" onerror="this.style.opacity=.25" />
          <div class="pbody">
            <div class="ptop">
              <div class="pname">${escapeHtml(p.name)}</div>
              <div class="pprice">$${money(p.price)}</div>
            </div>
            <div class="pdesc">${escapeHtml(p.desc)}</div>
            <div class="pactions">
              <button class="btn-mini btn-ghost" onclick="removeFromCart('${p.id}')">-</button>
              <button class="btn-mini btn" onclick="addToCart('${p.id}')">Agregar</button>
              <div class="qty">En carrito: <b id="qty-${p.id}">${qty}</b></div>
            </div>
          </div>
        </div>
      `;
    }).join("");
  }

  function renderCart(){
    const entries = [...state.cart.entries()];

    if (entries.length === 0){
      $("cartItems").innerHTML = `<div class="sub">Tu carrito está vacío.</div>`;
      $("total").textContent = "0.00";
      updateCreateSessionButtonFromTotal();
      return;
    }

    const lines = entries.map(([id, qty]) => {
      const p = state.catalog.find(x => x.id === id);
      const lineTotal = p.price * qty;
      return { p, qty, lineTotal };
    });

    const total = lines.reduce((a, b) => a + b.lineTotal, 0);
    $("total").textContent = money(total);

    $("cartItems").innerHTML = lines.map(({p, qty, lineTotal}) => `
      <div class="cart-item">
        <img src="${p.img}" alt="${escapeHtml(p.name)}" onerror="this.style.opacity=.25" />
        <div class="ci-main">
          <p class="ci-title">${escapeHtml(p.name)}</p>
          <div class="ci-sub">
            <span class="chip">${qty} × $${money(p.price)}</span>
            <span class="chip"><b>$${money(lineTotal)}</b></span>
          </div>
        </div>
        <div class="ci-controls">
          <button class="btn-mini btn-ghost" onclick="removeFromCart('${p.id}')">-</button>
          <button class="btn-mini btn-ghost" onclick="addToCart('${p.id}')">+</button>
        </div>
      </div>
    `).join("");

    updateCreateSessionButtonFromTotal();
  }

  function updateCatalogQty(id){
    const el = document.getElementById(`qty-${id}`);
    if (!el) return;
    el.textContent = String(state.cart.get(id) || 0);
  }

  function addToCart(id){
    state.cart.set(id, (state.cart.get(id) || 0) + 1);
    updateCatalogQty(id);
    renderCart();
  }

  function removeFromCart(id){
    const v = state.cart.get(id) || 0;
    if (v <= 1) state.cart.delete(id);
    else state.cart.set(id, v - 1);

    updateCatalogQty(id);
    renderCart();
  }

  function clearCart(){
	 state.cart.clear();
	 resetUxFlowState();
	 renderCatalog();
	 renderCart();
  }

  function lockCart(){
    document.querySelectorAll(".ci-controls button").forEach(b => b.disabled = true);
  }
  
  function handleGuestEmailInput() {
    const email = ($("email")?.value || "").trim();
    $("btnGuestContinue").disabled = !email;
  }

  function buildSessionsPayloadFromCart(){
    const entries = [...state.cart.entries()];
    const total = entries.reduce((sum, [id, qty]) => {
      const p = state.catalog.find(x => x.id === id);
      return sum + (p.price * qty);
    }, 0);

    return {
      version: "0.6",
      targetOrigins: [window.location.origin],
      data: {
        orderInformation: {
          amountDetails: {
            totalAmount: money(total),
            currency: "USD"
          }
        }
      },
      allowedCardNetworks: ["VISA", "MASTERCARD", "AMEX"],
      country: "US",
      locale: "en_US",
      billingType: "FULL"
    };
  }

  async function createSessionOnly(){
    try {
      const txt = ($("total")?.textContent || "0").trim();
      const total = Number(txt.replace(/[^0-9.]/g,""));

      if (!Number.isFinite(total) || total <= 0){
        throw new Error("Tu carrito está vacío. Agrega un producto antes de crear sesión.");
      }

      setStep("s1","warn","Running…");
      $("btnSession").disabled = true;

      const payload = buildSessionsPayloadFromCart();
      logLine("[UI] /api/sessions payload:", payload);

      const res = await fetch("/api/sessions", {
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify(payload)
      });

      const text = await res.text();

      if (!res.ok){
        const err = safeJsonParse(text);
        const msg = err?.message || text;
        throw new Error(`HTTP ${res.status}: ${msg}`);
      }

      const json = safeJsonParse(text);
      logLine("[API] /api/sessions response:", json);

      const clientLibrary = json.clientLibrary || json.client_library || json.libraryUrl;
      const integrity = json.clientLibraryIntegrity || json.integrity;
      const jwt = json.captureContextJwt || json.rawJwt || json.jwt || json.capture_context_jwt;

      if (!clientLibrary || !jwt){
        throw new Error("Respuesta /api/sessions no trae clientLibrary o jwt.");
      }

      state.session = { clientLibrary, integrity, jwt };
	  state.captureContextJwt = jwt;

	  state.captureContextDecoded = decodeJwtPayload(jwt);

	  state.panEncryptionKeys = extractPanEncryptionKeys(state.captureContextDecoded);

	  logLine("[CTX] captureContext decoded:", state.captureContextDecoded);
	  logLine("[CTX] PAN encryption keys:", state.panEncryptionKeys);
	  lockCart();
	  
	  

      setStep("s1","ok","Done");
      setStep("s2","", "Ready");

      $("btnInit").disabled = false;
      $("btnSession").disabled = false;

    } catch (e){
      logLine("[ERROR] createSessionOnly:", String(e?.message || e));
      setStep("s1","err","Error");
      $("btnSession").disabled = false;
    }
  }

    
  async function loadSdkScript(url, integrity){
    const existing = document.querySelector("script[data-uctp='1']");
    if (existing) existing.remove();

    logLine("[SDK] Loading clientLibrary:", url);
    if (integrity) logLine("[SDK] integrity:", integrity);

    return new Promise((resolve, reject) => {
      const s = document.createElement("script");
      s.src = url;
      s.async = true;
      s.defer = true;
      s.setAttribute("data-uctp", "1");

      if (integrity){
        s.integrity = integrity;
        s.crossOrigin = "anonymous";
      }

      s.onload = () => {
        logLine("[SDK] Script loaded. Global keys:", Object.keys(window).filter(k =>
          ["VSDK","UCTP","initialize","getCards","checkout","refreshCheckoutState"].includes(k)
        ));
        resolve();
      };

      s.onerror = () => reject(new Error("No se pudo cargar el clientLibrary JS (network/CORS/url)."));
      document.head.appendChild(s);
    });
  }
  
  function toggleCatalog(){

    const content = document.getElementById("catalogContent");
    const btn = document.getElementById("btnToggleCatalog");

    if(!content || !btn) return;

    if(content.style.display === "none"){

      content.style.display = "block";
	  btn.innerHTML = "▾";  // abierto
      logLine("[UI] Catalog expanded");
	  
	  
	 

    } else {

      content.style.display = "none";
	  btn.innerHTML = "▸";  // cerrado
      logLine("[UI] Catalog minimized");

    }

  }
  
  function getSdkHandle(){
    if (window.VSDK) return window.VSDK;
    if (window.UCTP) return window.UCTP;

    const hasGlobals =
      typeof window.initialize === "function" ||
      typeof window.getCards === "function" ||
      typeof window.checkout === "function";

    if (hasGlobals){
      return {
        initialize: window.initialize?.bind(window),
        getCards: window.getCards?.bind(window),
        checkout: window.checkout?.bind(window),
        refreshCheckoutState: window.refreshCheckoutState?.bind(window)
      };
    }

    throw new Error("SDK cargó el JS pero no expuso window.VSDK / window.UCTP ni funciones globales.");
  }

  


  
  
  function collapseCatalogIfOpen() {
    const content = document.getElementById("catalogContent");
    const btn = document.getElementById("btnToggleCatalog");

    if (content && content.style.display !== "none") {
      content.style.display = "none";
        if (btn) btn.innerHTML = "▸";
      logLine("[UI] Catalog minimized");
    }
  }
  
  function decodeJwtPayload(jwt){

    const parts = jwt.split(".");

    if (parts.length !== 3){
      throw new Error("JWT inválido.");
    }

    const payload = parts[1]
      .replace(/-/g, "+")
      .replace(/_/g, "/");

    const json = atob(payload);

    return JSON.parse(json);
  }
  
  function parseJwtPayload(jwt){
    const base64Url = jwt.split(".")[1];
    const base64 = base64Url.replace(/-/g, "+").replace(/_/g, "/");
    const jsonPayload = decodeURIComponent(
      atob(base64).split("").map(c =>
        "%" + ("00" + c.charCodeAt(0).toString(16)).slice(-2)
      ).join("")
    );
    return JSON.parse(jsonPayload);
  }

  function parseJwtPayloadUnsafe(jwt){
    const parts = String(jwt || "").split(".");

    if (parts.length !== 3){
      throw new Error("El valor no parece ser un JWT/JWS válido.");
    }

    const base64Url = parts[1];
    const base64 = base64Url.replace(/-/g, "+").replace(/_/g, "/");
    const padded = base64 + "=".repeat((4 - base64.length % 4) % 4);
    const json = atob(padded);

    return JSON.parse(json);
  }
  
  function base64UrlEncode(bytes) {
    let binary = "";
    for (const b of bytes) {
      binary += String.fromCharCode(b);
    }
    return btoa(binary).replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/g, "");
  }

  function base64UrlEncodeString(str) {
    return base64UrlEncode(new TextEncoder().encode(str));
  }
  
  function buildManualCardPayload(cardInfo, expiry, cvv) {
    const year4 = String(expiry.year).length === 2
      ? `20${expiry.year}`
      : String(expiry.year);

    return {
      primaryAccountNumber: cardInfo.pan,
      panExpirationMonth: expiry.month,
      panExpirationYear: year4,
      cardSecurityCode: cvv
    };
  }

  async function buildEncryptedCardFromManualEntry(cardInfo, expiry, cvv) {
    const network = detectCardNetworkFromPan(cardInfo.pan);

    if (!network) {
      throw new Error("Red de tarjeta no soportada.");
    }

    const jwk = state.panEncryptionKeys?.[network];

    if (!jwk) {
      throw new Error(
        `No hay panEncryptionKey para ${network}. Disponibles: ${Object.keys(state.panEncryptionKeys || {}).join(", ") || "ninguna"}`
      );
    }

    const cardPayload = buildManualCardPayload(cardInfo, expiry, cvv);

    logLine("[PAN-ENC] network selected:", network);
    logLine("[PAN-ENC] payload ready:", {
      primaryAccountNumber: "[REDACTED]",
      panExpirationMonth: cardPayload.panExpirationMonth,
      panExpirationYear: cardPayload.panExpirationYear,
      cardSecurityCode: "***"
    });

    const encryptedCard = await jweEncrypt(JSON.stringify(cardPayload), jwk);

    if (!encryptedCard) {
      throw new Error("No fue posible generar encryptedCard.");
    }

    return {
      encryptedCard,
      network
    };
  }
  
  async function continueGuestFlow() {
    try {
      validateShippingFields();

      logLine("[FLOW] Continue from guest shipping information");

      state.getCardsContext = "GUEST";

      $("btnGuestFlowContinue").disabled = true;
      setStep("s2", "warn", "Running Session, Initialize and getCards…");

      collapseCatalogIfOpen();

      await createSessionOnly();
      logLine("[FLOW] createSessionOnly() completed");

      await initialize();
      logLine("[FLOW] initialize() completed");

      await getCards();
      logLine("[FLOW] getCards() completed");

      setStep("s2", "ok", "Done");

    } catch (error) {
      logLine("[ERROR] continueGuestFlow:", error.message || error);
      setStep("s2", "err", "Error");
	  
	 } finally {
	      $("btnGuestFlowContinue").disabled = false;
	    }
}
  

  function extractJweFromCheckoutResponse(resp){

    if (!resp) return null;

    // Caso 1: resp es JWT firmado
    if (typeof resp === "string" && resp.split(".").length === 3){

      const jwtPayload = parseJwtPayloadUnsafe(resp);

    //  logLine("[DEBUG] checkout JWT payload:", jwtPayload);

      const nestedJwt =
        jwtPayload?.uctpCredentials?.payload ||
        jwtPayload?.payload;

      if (!nestedJwt) return null;

      const nestedPayload = parseJwtPayloadUnsafe(nestedJwt);

      //logLine("[DEBUG] nested JWT payload:", nestedPayload);

      const encrypted =
        nestedPayload?.encryptedPayload ||
        nestedPayload?.payload;

      return encrypted;
    }

    // Caso 2: objeto directo
    if (typeof resp === "object"){
      return (
        resp?.encryptedPayload ||
        resp?.paymentPayload ||
        resp?.jwe ||
        null
      );
    }

    return null;
  }  
  
  
  
  async function jweEncrypt(plaintext, jwk) {
    const publicKey = await crypto.subtle.importKey(
      "jwk",
      jwk,
      { name: "RSA-OAEP", hash: "SHA-256" },
      false,
      ["wrapKey"]
    );

    const cek = await crypto.subtle.generateKey(
      { name: "AES-GCM", length: 256 },
      true,
      ["encrypt"]
    );

    const wrappedKey = new Uint8Array(
      await crypto.subtle.wrapKey("raw", cek, publicKey, { name: "RSA-OAEP" })
    );

    const iv = crypto.getRandomValues(new Uint8Array(12));

    const header = {
      alg: "RSA-OAEP-256",
      enc: "A256GCM"
    };

    if (jwk.kid) {
      header.kid = jwk.kid;
    }

    const encodedHeader = base64UrlEncodeString(JSON.stringify(header));
    const aad = new TextEncoder().encode(encodedHeader);

    const plaintextBytes = new TextEncoder().encode(plaintext);

    const encrypted = await crypto.subtle.encrypt(
      {
        name: "AES-GCM",
        iv,
        additionalData: aad,
        tagLength: 128
      },
      cek,
      plaintextBytes
    );

    const encryptedBytes = new Uint8Array(encrypted);
    const ciphertext = encryptedBytes.slice(0, encryptedBytes.length - 16);
    const authTag = encryptedBytes.slice(encryptedBytes.length - 16);

    return [
      encodedHeader,
      base64UrlEncode(wrappedKey),
      base64UrlEncode(iv),
      base64UrlEncode(ciphertext),
      base64UrlEncode(authTag)
    ].join(".");
  }
  
   
  
  function extractPanEncryptionKeys(payload){

    const networks = ["SRCVISA","SRCMASTERCARD","SRCAMEX"];
    const keys = {};
    const ctx = payload?.ctx || [];

    for (const entry of ctx){

      const configs = entry?.data?.paymentConfigurations;

      if (!configs) continue;

      for (const network of networks){

        const key = configs?.[network]?.panEncryptionKey;

        if (key){
          keys[network] = key;
        }
      }
    }

    return keys;
  }
  
  
  
  function buildCaptureContext(jwt){
    return { raw: jwt, payload: parseJwtPayload(jwt) };
  }

  async function sdkInitialize(jwt){
    const sdk = state.sdk;
    if (!sdk || typeof sdk.initialize !== "function"){
      throw new Error("SDK initialize() no disponible.");
    }

    const captureContext = buildCaptureContext(jwt);
    const initOptions = {
      dpaTransactionOptions: {
        transactionAmount: {
          transactionAmount: "10.00",
          transactionCurrencyCode: "USD"
        }
      }
    };

    logLine("[SDK] Call initialize(captureContext, dpaTransactionOptions)");
    const r = await sdk.initialize(captureContext, initOptions);
    logLine("[SDK] initialize result:", r);
    window.__uctpInit = r;
    return r;
  }

  async function initializeSdkOnly(){
    try {
      if (!state.session?.clientLibrary || !state.session?.jwt){
        throw new Error("Primero ejecuta Crear sesión (paso 1).");
      }

      setStep("s2","warn","Running…");
      $("btnInit").disabled = true;
	  $("btnSession").disabled = true;
      await loadSdkScript(state.session.clientLibrary, state.session.integrity);

      const sdk = getSdkHandle();
      state.sdk = sdk;

      await sdkInitialize(state.session.jwt);

      setPill(true, "SDK: loaded");
      setStep("s2","ok","Done");
      setStep("s3","", "Ready");

      $("btnGetCards").disabled = false;
	  $("btnAddCard").disabled = false;

    } catch (e){
      logLine("[ERROR] initializeSdkOnly:", String(e?.message || e));
      setPill(false, "SDK: load/init failed");
      setStep("s2","err","Error");
      $("btnInit").disabled = false;
    }
  }

  
  function continueAsGuest() {
	collapseCatalogIfOpen();
	try {
      const email = ($("email")?.value || "").trim();

      if (!email) {
        throw new Error("Ingresa un email antes de continuar.");
      }

      logLine("[FLOW] Guest selected. Showing shipping information panel.");

      // guardar email en state si ya usas state global
      state.guestEmail = email;

      // ocultar vista inicial
      $("guestEntryView").style.display = "none";

      // mostrar vista de resumen + shipping
      $("guestShippingView").style.display = "block";

      // pintar email como label/resumen
      $("guestEmailLabel").textContent = email;

      setStep("s2", "", "Ready");
    } catch (error) {
      logLine("[ERROR] continueAsGuest:", error.message || error);
    }
  }
  
 
  

  function validateGuestShipping(){
    const requiredFields = [
      { id: "firstName", label: "First Name" },
      { id: "lastName", label: "Last Name" },
      { id: "mobileNumber", label: "Mobile Number" },
      { id: "address1", label: "Address Line 1" },
      { id: "country", label: "Country" },
      { id: "city", label: "City/Town" },
      { id: "state", label: "State" },
      { id: "zip", label: "Zip" }
    ];

    for(const field of requiredFields){
      const value = ($(field.id)?.value || "").trim();
      if(!value){
        throw new Error(`Completa el campo ${field.label}.`);
      }
    }
  }
  
  function updateUxEmptyState(){
    const hasVisiblePanel =
      !$("otpPanel").classList.contains("hidden") ||
      !$("savedCardsPanel").classList.contains("hidden") ||
      !$("guestCardPanel").classList.contains("hidden");

    $("uxEmptyState").classList.toggle("hidden", hasVisiblePanel);
  }

  function showOtpPanel(show, message){
    $("otpPanel").classList.toggle("hidden", !show);
    if (show){
      if (message) $("otpMessage").textContent = message;
      $("savedCardsPanel").classList.add("hidden");
      $("guestCardPanel").classList.add("hidden");
    }
    updateUxEmptyState();
  }

  function showSavedCardsPanel(show){
    $("savedCardsPanel").classList.toggle("hidden", !show);
    if (show){
      $("guestCardPanel").classList.add("hidden");
      $("otpPanel").classList.add("hidden");
    }
    updateUxEmptyState();
  }

  function showGuestCardPanel(show){
    $("guestCardPanel").classList.toggle("hidden", !show);

    if (show){
      $("otpPanel").classList.add("hidden");
      $("savedCardsPanel").classList.add("hidden");
      state.currentUxFlow = "MANUAL_CARD";
	  setStep("s3b","warn","Entering Card");
	  updateFlowIndicator("LINK_CARD");
      $("guestCardNumber").value = "";
      $("guestExpiry").value = "";
      $("cvv").value = "";
      $("linkCardToCtp").checked = false;
	  setCheckoutButtonsEnabled(true);
      updateGuestCardBrandUI();
    }

    updateUxEmptyState();
  }

  function normalizeBrandName(card){
    const rawBrand = String(
      card?.paymentCardDescriptor ||
      card?.paymentCardBrand ||
      card?.brand ||
      ""
    ).toUpperCase();

    if (rawBrand.includes("VISA")) return "VISA";
    if (rawBrand.includes("MASTERCARD")) return "MASTERCARD";
    if (rawBrand.includes("AMEX") || rawBrand.includes("AMERICAN EXPRESS")) return "AMEX";
    return "CARD";
  }

  function getBrandLogo(brand){
    switch (brand) {
      case "VISA":
        return STATIC_ASSETS.visaLogo;
      case "AMEX":
        return STATIC_ASSETS.amexLogo;
      case "MASTERCARD":
        return STATIC_ASSETS.mcLogoFallback;
      default:
        return "";
    }
  }

  function getCardArtFromSdk(card){
    const uri = card?.digitalCardData?.artUri || "";
    return uri || "";
  }

  function getCardArt(brand, card){
    const sdkArt = getCardArtFromSdk(card);
    if (sdkArt) return sdkArt;

    switch (brand) {
      case "VISA":
        return STATIC_ASSETS.visaArt;
      case "AMEX":
        return STATIC_ASSETS.amexArt;
      case "MASTERCARD":
        return STATIC_ASSETS.mcArt;
      default:
        return STATIC_ASSETS.ctpIcon;
    }
  }

  function getCardDisplayTitle(card, brand){
    const type = String(card?.paymentCardType || "").toUpperCase();

    if (type === "DEBIT") return "Bank Debit";
    if (type === "CREDIT") return "Credit Card";
    if (brand === "AMEX") return "American Express";
    return "Card Payment";
  }

  function detectNetwork(card){
    const first = card.substring(0,1);
    const digit2 = card.substring(0,2);

    if (digit2 === "34" || digit2 === "37") return "AMEX";
    if (first === "5" || first === "2") return "MASTERCARD";
    if (first === "4") return "VISA";
    return "UNKNOWN";
  }

  function getRawCardNumber(){
    return ($("guestCardNumber").value || "").replace(/\D/g, "");
  }

  
  function detectCardNetworkFromPan(pan) {
    const clean = String(pan || "").replace(/\D/g, "");

    if (/^4/.test(clean)) return "SRCVISA";
    if (/^(5[1-5]|222[1-9]|22[3-9]\d|2[3-6]\d{2}|27[01]\d|2720)/.test(clean)) return "SRCMASTERCARD";
    if (/^(34|37)/.test(clean)) return "SRCAMEX";

    return null;
  }
  
  function formatCardNumberInput(input){
    let value = input.value || "";

    value = value.replace(/\D/g, "");
    value = value.substring(0, 19);

    const network = detectNetwork(value);

    let formatted = "";

    if (network === "AMEX"){
      const p1 = value.substring(0, 4);
      const p2 = value.substring(4, 10);
      const p3 = value.substring(10, 15);
      formatted = [p1, p2, p3].filter(Boolean).join(" ");
    } else {
      for (let i = 0; i < value.length; i++){
        if (i > 0 && i % 4 === 0) formatted += " ";
        formatted += value[i];
      }
    }

    input.value = formatted;
    updateGuestCardBrandUI();
  }

  function formatExpiryInput(input){
    let value = (input.value || "").replace(/\D/g, "").substring(0, 4);

    if (value.length >= 3){
      value = value.substring(0, 2) + "/" + value.substring(2);
    }

    input.value = value;
  }

  function getBrandLogoFromNetwork(network){
    switch (network){
      case "VISA":
        return STATIC_ASSETS.visaLogo;
      case "AMEX":
        return STATIC_ASSETS.amexLogo;
      case "MASTERCARD":
        return STATIC_ASSETS.mcLogoFallback;
      default:
        return "";
    }
  }

  function getBrandArtFromNetwork(network){
    switch (network){
      case "VISA":
        return STATIC_ASSETS.visaArt;
      case "AMEX":
        return STATIC_ASSETS.amexArt;
      case "MASTERCARD":
        return STATIC_ASSETS.mcArt;
      default:
        return STATIC_ASSETS.genericCardArt || STATIC_ASSETS.ctpIcon;
    }
  }

  function updateGuestCardBrandUI(){
    const pan = getRawCardNumber();
    const network = detectNetwork(pan);

    const logo = $("guestCardBrandLogo");
    const text = $("guestCardBrandText");

    if (!pan){
      logo.style.display = "none";
      logo.src = "";
      text.textContent = "";
      return;
    }

    if (network === "UNKNOWN"){
      logo.style.display = "none";
      logo.src = "";
      text.textContent = "Marca no identificada aún";
      return;
    }

    const logoSrc = getBrandLogoFromNetwork(network);

    if (logoSrc){
      logo.src = logoSrc;
      logo.style.display = "block";
    } else {
      logo.style.display = "none";
      logo.src = "";
    }

    text.textContent = `${network}`;
  }

  function validateCardNumber(){
    const pan = getRawCardNumber();
    const network = detectNetwork(pan);

    if (!pan){
      throw new Error("Ingresa número de tarjeta.");
    }

    if (network === "AMEX"){
      if (pan.length !== 15){
        throw new Error("American Express debe tener 15 dígitos.");
      }
    } else {
      if (pan.length < 13 || pan.length > 19){
        throw new Error("Número de tarjeta inválido.");
      }
    }

    if (!passesLuhn(pan)){
      throw new Error("Número de tarjeta inválido.");
    }

    return {
      pan,
      network
    };
  }

  function passesLuhn(value){
    let sum = 0;
    let shouldDouble = false;

    for (let i = value.length - 1; i >= 0; i--){
      let digit = parseInt(value.charAt(i), 10);

      if (shouldDouble){
        digit *= 2;
        if (digit > 9) digit -= 9;
      }

      sum += digit;
      shouldDouble = !shouldDouble;
    }

    return sum % 10 === 0;
  }

  function validateExpiry(){
    const value = ($("guestExpiry").value || "").trim();

    if (!/^\d{2}\/\d{2}$/.test(value)){
      throw new Error("La fecha de expiración debe tener formato MM/YY.");
    }

    const [mm, yy] = value.split("/");
    const month = Number(mm);
    const year = Number(yy);

    if (month < 1 || month > 12){
      throw new Error("Mes de expiración inválido.");
    }

    const now = new Date();
    const currentYear = now.getFullYear() % 100;
    const currentMonth = now.getMonth() + 1;

    if (year < currentYear || (year === currentYear && month < currentMonth)){
      throw new Error("La tarjeta está expirada.");
    }

    return {
      month: mm,
      year: yy
    };
  }

  function validateCvv(network){
    const cvv = ($("cvv").value || "").replace(/\D/g, "");

    if (!cvv){
      throw new Error("Ingresa CVV.");
    }

    if (network === "AMEX"){
      if (cvv.length !== 4){
        throw new Error("AMEX requiere CVV de 4 dígitos.");
      }
    } else {
      if (cvv.length !== 3){
        throw new Error("El CVV debe tener 3 dígitos.");
      }
    }

    return cvv;
  }
  

  async function runExistingUserLookup() {
    try {
      logLine("[FLOW] Existing user lookup started");

      state.getCardsContext = "EXISTING";

      collapseCatalogIfOpen();

      await getCards();

    } catch (error) {
      logLine("[ERROR] runExistingUserLookup:", error.message || error);
    }
  }
  
  function isAddCardError(err) {
    const details = err?.error?.details || err?.details || [];
    const text = JSON.stringify(details).toUpperCase();

    return text.includes("ADD_CARD") || text.includes("ADD CARD");
  }

  function isGuestFallbackError(err) {
    return (
      err?.name === "UctpSdkError" &&
      (err?.error?.reason === "ERROR" || err?.reason === "ERROR") &&
      Array.isArray(err?.error?.details) &&
      err.error.details.some(d => d?.reason === "UNKNOWN_ERROR")
    );
  }

  async function getCards() {
    try {
      resetUxFlowState();
      state.currentUxFlow = "GET_CARDS";

      setStep("s3", "warn", "Running…");
      $("btnGetCards").disabled = true;

      const email =
        state.getCardsContext === "GUEST"
          ? (state.guestEmail || $("email")?.value || "").trim()
          : ($("email")?.value || "").trim();

      if (!email) {
        throw new Error("Ingresa email para getCards().");
      }

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        throw new Error("El email no tiene un formato válido para getCards().");
      }

      if (!state.sdk?.getCards) {
        throw new Error("SDK getCards() no disponible.");
      }

      state.pendingConsumerIdentity = null;

      const consumerIdentity = {
        identityProvider: "SRC",
        identityType: "EMAIL_ADDRESS",
        identityValue: email
      };

      logLine("[SDK] getCards({ consumerIdentity })");
      logLine("[DEBUG] email used for getCards:", email);
      logLine("[DEBUG] consumerIdentity:", JSON.stringify(consumerIdentity));
      logLine("[DEBUG] getCards context:", state.getCardsContext || "UNKNOWN");

      const cardsResp = await state.sdk.getCards({ consumerIdentity });

      logLine("[SDK] getCards result:", cardsResp);
      updateFlowIndicator("EXISTING_USER");

      const actionCode = cardsResp?.actionCode || "";

      if (actionCode === "SUCCESS") {
        logLine("[FLOW] SUCCESS → cards available");

        processCards(cardsResp);
        showSavedCardsPanel(true);
        showGuestCardPanel(false);
        showOtpPanel(false);

        setStep("s3", "ok", "Done");
        setStep("s4", "", "Ready");

        setCheckoutButtonsEnabled(state.cards.length > 0);
        return;
      }

      if (actionCode === "PENDING_CONSUMER_IDV") {
        logLine("[FLOW] Consumer recognized → OTP required");
		
		state.getCardsContext = "EXISTING";
        state.pendingConsumerIdentity = consumerIdentity;
        logLine("[FLOW] Pending consumer stored:", state.pendingConsumerIdentity);

        showOtpPanel(
          true,
          `Click to Pay ha encontrado sus tarjetas. Ingresa el código enviado a ${cardsResp?.maskedValidationChannel || "tu canal"} para continuar`
        );

        showSavedCardsPanel(false);
        showGuestCardPanel(false);

        setStep("s3", "warn", "OTP Required");
        setStep("s3b", "", "Ready");
        setStep("s4", "", "Ready");

        setCheckoutButtonsEnabled(false);
        return;
      }

      if (actionCode === "ADD_CARD") {
        logLine("[FLOW] Guest consumer → ADD_CARD");

        showOtpPanel(false);
        showSavedCardsPanel(false);
        showGuestCardPanel(true);

        setStep("s3", "warn", "Add Card");
        setStep("s3b", "warn", "Entering Card");
        setStep("s4", "", "Ready");

        setCheckoutButtonsEnabled(false);
        return;
      }

      if (actionCode === "ERROR") {
        throw new Error(
          `SRC ERROR: ${cardsResp?.reason || "UNKNOWN"} - ${cardsResp?.message || ""}`
        );
      }

      throw new Error(`Unknown actionCode returned by getCards(): ${actionCode || "EMPTY"}`);

    } catch (e) {
      logLine("[ERROR] getCards:", String(e?.message || e));
      logLine("[ERROR] getCards raw:", JSON.stringify(e, null, 2));
      logLine("[ERROR] getCards name:", e?.name || "");
      logLine("[ERROR] getCards message:", e?.message || "");
      logLine("[ERROR] getCards reason:", e?.error?.reason || e?.reason || "");
      logLine("[ERROR] getCards details:", JSON.stringify(e?.error?.details || e?.details || [], null, 2));
      logLine("[DEBUG] getCards context:", state.getCardsContext || "UNKNOWN");

      const isGuestContext = state.getCardsContext === "GUEST";

      if (isGuestContext && (isAddCardError(e) || isGuestFallbackError(e))) {
        logLine("[FLOW] Guest consumer detected from error → ADD_CARD fallback");

        showOtpPanel(false);
        showSavedCardsPanel(false);
        showGuestCardPanel(true);

        setStep("s3", "warn", "Add Card");
        setStep("s3b", "warn", "Entering Card");
        setStep("s4", "", "Ready");

        setCheckoutButtonsEnabled(false);
        return;
      }

      if (state.getCardsContext === "EXISTING") {
        logLine("[FLOW] Existing user lookup failed before OTP/SUCCESS response.");
      }

      setStep("s3", "err", "Error");
      setCheckoutButtonsEnabled(false);

    } finally {
      $("btnGetCards").disabled = false;
    }
  }
  
  
  async function verifyOtp() {
    try {
      const otp = ($("otpCode")?.value || "").trim();

      if (!otp) {
        throw new Error("Ingresa el OTP.");
      }

      if (!state.pendingConsumerIdentity) {
        throw new Error("No hay consumerIdentity pendiente.");
      }
	
      if (!state.sdk?.getCards) {
        throw new Error("SDK getCards() no disponible.");
      }

      setStep("s3", "warn", "Verifying OTP…");
      $("btnOtp").disabled = true;

      const consumerIdentity = state.pendingConsumerIdentity;

      logLine("[OTP] consumerIdentity:", consumerIdentity);
      logLine("[DEBUG] verifyOtp context:", state.getCardsContext || "UNKNOWN");
      logLine("[SDK] getCards({ consumerIdentity, validationData })");

      const cardsResp = await state.sdk.getCards({
        consumerIdentity,
        validationData: otp
      });

      logLine("[SDK] getCards after OTP:", cardsResp);

      const actionCode = cardsResp?.actionCode || "";

      if (actionCode === "SUCCESS") {
        logLine("[FLOW] OTP verified → cards returned");

        processCards(cardsResp);

        state.pendingConsumerIdentity = null;

        showOtpPanel(false);
        showGuestCardPanel(false);
        showSavedCardsPanel(true);
        updateFlowIndicator("EXISTING_USER");

        setStep("s3", "ok", "Done");
        setStep("s3b", "ok", "Ready");
     

        setCheckoutButtonsEnabled(state.cards.length > 0);
        return;
      }

      if (actionCode === "ADD_CARD") {
        logLine("[FLOW] OTP verified → ADD_CARD");

        state.pendingConsumerIdentity = null;

        showOtpPanel(false);
        showSavedCardsPanel(false);
        showGuestCardPanel(true);

        setStep("s3", "warn", "Add Card");
        setStep("s3b", "warn", "Entering Card");
        setStep("s4", "", "Ready");

        setCheckoutButtonsEnabled(false);
        return;
      }

      if (actionCode === "PENDING_CONSUMER_IDV") {
        logLine("[FLOW] OTP invalid or still pending");

        setStep("s3", "warn", "Retry OTP");
        setStep("s3b", "warn", "Retry OTP");
        setCheckoutButtonsEnabled(false);
        return;
      }

      if (actionCode === "ERROR") {
        throw new Error(
          `SRC ERROR: ${cardsResp?.reason || "UNKNOWN"} - ${cardsResp?.message || ""}`
        );
      }

      throw new Error(`Respuesta inesperada después del OTP: ${actionCode || "EMPTY"}`);

    } catch (e) {
      logLine("[ERROR] verifyOtp:", String(e?.message || e));
      logLine("[ERROR] verifyOtp raw:", JSON.stringify(e, null, 2));
      logLine("[ERROR] verifyOtp name:", e?.name || "");
      logLine("[ERROR] verifyOtp message:", e?.message || "");
      logLine("[ERROR] verifyOtp reason:", e?.error?.reason || e?.reason || "");
      logLine(
        "[ERROR] verifyOtp details:",
        JSON.stringify(e?.error?.details || e?.details || [], null, 2)
      );
      logLine("[DEBUG] verifyOtp context:", state.getCardsContext || "UNKNOWN");

      setStep("s3", "err", "OTP Error");
      setStep("s3b", "err", "OTP Error");
      setCheckoutButtonsEnabled(false);

    } finally {
      $("btnOtp").disabled = false;
    }
  }
  
  
  function processCards(cardsResp){
  //  logLine("[processCards] input:", cardsResp);
  //  logLine("[processCards] profiles:", cardsResp?.profiles);

    const profiles = cardsResp?.profiles || [];
    const cards = [];

    profiles.forEach((profile, pIndex) => {
      const maskedCards = profile?.maskedCards || profile?.cards || [];

      maskedCards.forEach((card, cIndex) => {
        const brand = normalizeBrandName(card);

        cards.push({
          profileIndex: pIndex,
          cardIndex: cIndex,
          brand,
          title: getCardDisplayTitle(card, brand),
          maskedCardNumber:
            card?.maskedCardNumber ||
            (card?.panLastFour ? `•••• ${card.panLastFour}` : "••••"),
          last4: card?.panLastFour || "",
          expirationMonth:
            card?.panExpirationMonth ||
            card?.expirationMonth ||
            "",
          expirationYear:
            card?.panExpirationYear ||
            card?.expirationYear ||
            "",
          srcDigitalCardId: card?.srcDigitalCardId || "",
          brandLogo: getBrandLogo(brand),
          cardArt: getCardArt(brand, card),
          raw: card
        });
      });
    });

    state.cards = cards;
    state.selectedCardIndex = 0;

   // logLine("[processCards] normalized cards:", state.cards);

    const list = $("savedCardsList");

    if (!list){
      logLine("[ERROR] processCards: no existe #savedCardsList");
      return;
    }

	if (!cards.length){
	  list.innerHTML = `<div style="padding:8px;color:#64748b;">No hay tarjetas disponibles para mostrar todavía.</div>`;
	  return;
	}

    list.innerHTML = cards.map((c, idx) => `
      <label class="saved-card">
        <input
          type="radio"
          name="savedCard"
          value="${idx}"
          ${idx === 0 ? "checked" : ""}
          onclick="selectCard(${idx})"
        />

        <img
          src="${c.cardArt}"
          alt="${escapeHtml(c.brand)} card art"
          class="saved-card-art"
          onerror="this.src=STATIC_ASSETS.ctpIcon"
        />

        <div class="saved-card-main">
          <div class="saved-card-title">${escapeHtml(c.title)}</div>

          <div class="saved-card-meta">
            ${c.brandLogo ? `
              <img
                src="${c.brandLogo}"
                alt="${escapeHtml(c.brand)}"
                class="saved-card-brand-logo"
                onerror="this.style.display='none'"
              />
            ` : ""}

            <span class="saved-card-last4">
              ${c.last4 ? `•••• ${escapeHtml(c.last4)}` : escapeHtml(c.maskedCardNumber)}
            </span>

            ${
              c.expirationMonth && c.expirationYear
                ? `<span class="saved-card-expiry">Exp ${escapeHtml(c.expirationMonth)}/${escapeHtml(c.expirationYear)}</span>`
                : ""
            }
          </div>
        </div>
      </label>
    `).join("");
  }

  function selectCard(idx){
    state.selectedCardIndex = idx;
  }

  
  function updateFlowIndicator(flow){

    const text = $("flowText");
    const dot = $("flowPill").querySelector(".dot");

    if(flow === "EXISTING_USER"){

      text.textContent = "FLOW: Existing User (OTP)";
      dot.className = "dot ok";
      return;
    }

    if(flow === "LINK_CARD"){

      text.textContent = "FLOW: Linking Card";
      dot.className = "dot warn";
      return;
    }

    if(flow === "CHECKOUT"){

      text.textContent = "FLOW: Checkout Processing";
      dot.className = "dot warn";
      return;
    }

    text.textContent = "FLOW: waiting";
    dot.className = "dot";
  }

  
 
  async function submitNewCardCheckout() {
    try {
      updateFlowIndicator("CHECKOUT");
      setCheckoutButtonsEnabled(false);

      if (!state.sdk?.checkout) {
        throw new Error("SDK checkout() no disponible.");
      }

      const email = (state.guestEmail || $("email")?.value || "").trim();
      if (!email) {
        throw new Error("Ingresa email.");
      }

      const cardInfo = validateCardNumber();
      const expiry = validateExpiry();
      const cvv = validateCvv(cardInfo.network);
      const total = parseFloat($("total").textContent || "0");
      const linkCard = !!$("linkCardToCtp")?.checked;

      logLine("[BIN] network detected:", cardInfo.network);
      logLine("[FLOW] linkCardToCtp checked:", linkCard);

      // -----------------------------
      // FLUJO 1: NUEVA TARJETA + CTP
      // -----------------------------
      if (linkCard) {
        setStep("s4", "warn", "Building + Encrypting Card…");

        const { encryptedCard, network } =
          await buildEncryptedCardFromManualEntry(cardInfo, expiry, cvv);

        logLine("[PAN-ENC] encryptedCard generated:", "[JWE]");
        logLine("[FLOW] network for add card:", network);

        const checkoutParameters = {
          encryptedCard,
          consumer: {
            identityProvider: "SRC",
            identityType: "EMAIL_ADDRESS",
            identityValue: email
          },
          dpaTransactionOptions: {
            transactionAmount: {
              transactionAmount: money(total),
              transactionCurrencyCode: "USD"
            }
          },
          payloadTypeIndicatorCheckout: "FULL",
          storeCard: true
        };

        setStep("s4", "warn", "Calling CTP checkout()…");

        logLine("[SDK] Checkout(New Card + Link to CTP):", {
          ...checkoutParameters,
          encryptedCard: "[JWE]"
        });

        const resp = await state.sdk.checkout(checkoutParameters);

        logLine("[SDK] New Card + CTP checkout result:", resp);

        const maybeJwe = extractJweFromCheckoutResponse(resp);

        if (maybeJwe) {
          await decryptAndLogJwe(maybeJwe);
        } else {
          logLine("[DEBUG] No JWE found to decrypt.");
        }

        return await handleManualCheckoutResponse(resp);
      }

      // -----------------------------------------
      // FLUJO 2: NUEVA TARJETA SIN CTP / PASARELA
      // -----------------------------------------
      setStep("s4", "warn", "Processing Gateway Payment…");

      const gatewayPayload = {
        card: {
          number: "[REDACTED]",
          expiryMonth: expiry.month,
          expiryYear: String(expiry.year).length === 2 ? `20${expiry.year}` : String(expiry.year),
          cvv: "***",
          network: cardInfo.network
        },
        amount: money(total),
        currency: "USD",
        email
      };

      logLine("[GW] Normal gateway payment payload:", gatewayPayload);

      // Demo simulado
      await new Promise(resolve => setTimeout(resolve, 1200));

      const simulatedGatewayResponse = {
        status: "AUTHORIZED",
        processor: "GATEWAY",
        amount: money(total),
        currency: "USD",
        message: "Pago exitoso simulado por pasarela."
      };

      logLine("[GW] Simulated gateway response:", simulatedGatewayResponse);

      showOtpPanel(false);
      showSavedCardsPanel(false);
      showGuestCardPanel(false);
	  updateUxEmptyState();
	  
      setStep("s4", "ok", "Done");
      setCheckoutButtonsEnabled(true);

	  logLine("[GW] Payment processed via gateway without CTP (simulation)");

	  showPaymentSuccessPanel(true);

	  setStep("s4", "ok", "Done");

	  setCheckoutButtonsEnabled(true);

      return simulatedGatewayResponse;

    } catch (e) {
      logLine("[ERROR] submitNewCardCheckout:", String(e?.message || e));

      if (String(e?.message || e).includes("CARD_ADD_FAILED")) {
        logLine("[FLOW] La vinculación de la tarjeta a Click to Pay falló.");
        logLine("[TIP] Si no deseas vincularla, deja el checkbox desmarcado para procesar pago normal por pasarela.");
      }

      setStep("s4", "err", "Error");
      setCheckoutButtonsEnabled(true);
      throw e;
    }
  }    
  async function submitExistingCardCheckout() {
    try {
      setStep("s4", "warn", "Running…");
      setCheckoutButtonsEnabled(false);

	  if (!state.sdk?.checkout) {
	     throw new Error("SDK checkout() no disponible.");
	   }

	   if (!state.cards || state.cards.length === 0) {
	     throw new Error("No hay tarjetas. Ejecuta getCards().");
	   }

	   const selected = state.cards[state.selectedCardIndex];

	   if (!selected?.srcDigitalCardId) {
	     throw new Error("La tarjeta seleccionada no tiene srcDigitalCardId.");
	   }

      const total = parseFloat($("total").textContent || "0");

      const checkoutParameters = {
        srcDigitalCardId: selected.srcDigitalCardId,
        dpaTransactionOptions: {
          transactionAmount: {
            transactionAmount: money(total),
            transactionCurrencyCode: "USD"
          }
        },
        payloadTypeIndicatorCheckout: "FULL"
      };

      logLine("[SDK] Existing checkout(checkoutParameters):", checkoutParameters);

      const resp = await state.sdk.checkout(checkoutParameters);

      logLine("[SDK] Existing checkout result:", resp);

      const maybeJwe = extractJweFromCheckoutResponse(resp);

      if (maybeJwe) {
        await decryptAndLogJwe(maybeJwe);
      } else {
        logLine("[DEBUG] No JWE found to decrypt.");
      }

      setStep("s4", "ok", "Done");
      setCheckoutButtonsEnabled(true);

      return resp;

    } catch (e) {
      logLine("[ERROR] existing checkout:", String(e?.message || e));
      setStep("s4", "err", "Error");
      setCheckoutButtonsEnabled(true);
      throw e;
    }
  }
  
  
  async function submitCheckout() {
    try {
      if (isNewCardSelected()) {
        logLine("[FLOW] New card selected");
        return await submitNewCardCheckout();
        
      }

      logLine("[FLOW] Existing card selected");
      return await submitExistingCardCheckout();

    } catch (e) {
      logLine("[ERROR] submitCheckout:", String(e?.message || e));
      setStep("s4", "err", "Error");
      setCheckoutButtonsEnabled(true);
	  throw e;
    }
  }  
  
  async function decryptAndLogJwe(jwe){
    try {
      logLine("[DEBUG] JWE detected. Sending to backend for decryption...");
	//  logLine("[DEBUG] JWE preview:", jwe.substring(0,60) + "...");
    //  logLine("[DEBUG] JWE parts:", String(jwe).split(".").length);

      const res = await fetch("/api/debug/decrypt-jwe", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ jwe })
      });

    //  logLine("[DEBUG] decrypt endpoint status:", res.status);

      const text = await res.text();
   //   logLine("[DEBUG] decrypt raw response:", text);

      let json = {};
      try {
        json = JSON.parse(text);
      } catch (_) {}

      if (!res.ok) {
        throw new Error(`HTTP ${res.status}: ${text}`);
      }

      if (!json.success) {
        throw new Error(json.error || "No fue posible desencriptar el JWE");
      }

      let pretty = json.decryptedPayload;

      try {
        pretty = JSON.stringify(JSON.parse(json.decryptedPayload), null, 2);
      } catch (_) {}

      logLine("[DEBUG] Decrypted JWE payload:");
      logLine(pretty);

    } catch (e) {
      logLine("[ERROR] decryptAndLogJwe:", String(e?.message || e));
    }
  }
  
  
  
  function isNewCardSelected() {
	const panel = document.getElementById("guestCardPanel");
	 return panel && !panel.classList.contains("hidden");
  }

    
  async function handleManualCheckoutResponse(resp) {
    const actionCode = resp?.actionCode || "";

    logLine("[FLOW] handleManualCheckoutResponse actionCode:", actionCode);

    if (actionCode === "SUCCESS") {
      logLine("[FLOW] Manual new card checkout SUCCESS");

      showOtpPanel(false);
      showSavedCardsPanel(false);
      showGuestCardPanel(false);

      setStep("s4", "ok", "Done");
      setCheckoutButtonsEnabled(true);

      return resp;
    }

    if (actionCode === "ERROR") {
      const reason = resp?.reason || "UNKNOWN";
      const message = resp?.message || "";

      logLine("[FLOW] Manual new card checkout ERROR:", {
        reason,
        message
      });

      throw new Error(`SRC ERROR: ${reason}${message ? " - " + message : ""}`);
    }

    if (actionCode === "PENDING_CONSUMER_IDV") {
      logLine("[FLOW] Manual new card checkout returned PENDING_CONSUMER_IDV");

      showOtpPanel(
        true,
        `Click to Pay requiere validación adicional. Ingresa el código enviado a ${resp?.maskedValidationChannel || "tu canal"} para continuar.`
      );

      setStep("s4", "warn", "OTP Required");
      setCheckoutButtonsEnabled(true);

      return resp;
    }

    if (actionCode === "REQUIRES_ACTION") {
      logLine("[FLOW] Manual new card checkout REQUIRES_ACTION:", resp);

      setStep("s4", "warn", "Action Required");
      setCheckoutButtonsEnabled(true);

      return resp;
    }

    logLine("[FLOW] Manual new card checkout unknown actionCode:", actionCode);
    logLine("[FLOW] Full manual checkout response:", resp);

    setStep("s4", "ok", "Done");
    setCheckoutButtonsEnabled(true);

    return resp;
  }
  
  function showPaymentSuccessPanel(show){

    const panel = $("paymentSuccessPanel");

    if (!panel) return;

    panel.classList.toggle("hidden", !show);

    if (show){

      $("guestCardPanel")?.classList.add("hidden");
      $("savedCardsPanel")?.classList.add("hidden");
      $("otpPanel")?.classList.add("hidden");

    }

    updateUxEmptyState();
  }
  
  function resetUxFlowState(){
    state.cards = [];
    state.selectedCardIndex = 0;
    state.pendingManualCheckout = null;
    $("otpCode").value = "";
    $("guestCardNumber").value = "";
    $("guestExpiry").value = "";
    $("cvv").value = "";
    $("linkCardToCtp").checked = false;

    const list = $("savedCardsList");
    if (list) list.innerHTML = "";

    showOtpPanel(false);
    showSavedCardsPanel(false);
    showGuestCardPanel(false);

    updateGuestCardBrandUI();
    setCheckoutButtonsEnabled(false);
  }
  
  
  function init(){
    setPill(null, "SDK: not loaded");
    renderCatalog();
    renderCart();

    logLine("[UI] Ready.");

    setStep("s1","", "Ready");
    setStep("s2","", "Locked");
    setStep("s3","", "Locked");
    setStep("s4","", "Locked");

    $("btnInit").disabled = true;
    $("btnGetCards").disabled = true;
    setCheckoutButtonsEnabled(false);

    updateUxEmptyState();
  }

  init();
</script>
</body>
</html>
